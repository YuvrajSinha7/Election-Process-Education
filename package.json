{
  "name": "election-process-education",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate && npm run sync-assets",
    "sync-assets": "mkdir -p public && cp -r js css data index.html public/ || xcopy /E /I /Y js public\\js && xcopy /E /I /Y css public\\css && xcopy /E /I /Y data public\\data && copy index.html public\\"
  },
  "dependencies": {
    "@google/generative-ai": "^0.1.0",
    "@prisma/client": "^5.10.2",
    "bcrypt": "^5.1.1",
    "next": "14.1.0",
    "next-auth": "^4.24.5",
    "prisma": "^5.10.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.58",
    "@types/react-dom": "^18.2.19",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
